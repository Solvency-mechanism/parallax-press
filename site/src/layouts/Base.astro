---
const { title, page = 'entry', current = '', styles = [] } = Astro.props;
const domains = ['Labor','Capital','The State','Ideology','History','Institutions'];
const dslug = (d) => d.toLowerCase().replace(/&/g,'and').replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'');
---
<!DOCTYPE html>
<html lang="en" data-page={page} data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<link rel="stylesheet" href="/assets/press.css" />
{styles.map((href) => <link rel="stylesheet" href={href} />)}
<script is:inline>
  (function () { try {
    var t = localStorage.getItem("pp-theme") || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    document.documentElement.setAttribute("data-theme", t);
  } catch (e) {} })();
</script>
</head>
<body>
<a class="skip-link" href="#content">Skip to content</a>
<header class="site-header">
  <div class="header-inner">
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="site-nav">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" width="20" height="20"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg>
    </button>
    <a class="brand" href="/" aria-label="Common Knowledge Project home">
      <svg class="seal" viewBox="0 0 200 200" aria-hidden="true" width="26" height="26"><g fill="none" stroke="currentColor" stroke-width="4"><circle cx="100" cy="100" r="92"/><circle cx="100" cy="100" r="64"/></g><g fill="currentColor"><path d="M100 46 L104 54 L112 58 L104 62 L100 70 L96 62 L88 58 L96 54 Z"/></g></svg>
      <span class="brand-words"><span class="brand-name">The Common Knowledge Project</span><span class="brand-sub">a Parallax Press reference archive</span></span>
    </a>
    <form class="header-search" role="search" action="/" onsubmit="return false">
      <input type="search" id="site-search" placeholder="Search the archive" aria-label="Search the archive" />
    </form>
    <button class="icon-btn" id="theme-toggle" aria-label="Toggle dark mode">
      <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" width="20" height="20"><circle cx="12" cy="12" r="4.2"/><g stroke-linecap="round"><line x1="12" y1="2.5" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="21.5"/><line x1="2.5" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="21.5" y2="12"/><line x1="5.2" y1="5.2" x2="6.9" y2="6.9"/><line x1="17.1" y1="17.1" x2="18.8" y2="18.8"/><line x1="18.8" y1="5.2" x2="17.1" y2="6.9"/><line x1="6.9" y1="17.1" x2="5.2" y2="18.8"/></g></svg>
      <svg class="ic-moon" viewBox="0 0 24 24" fill="currentColor" width="20" height="20" style="display:none"><path d="M20 14.5A8 8 0 0 1 9.5 4 8 8 0 1 0 20 14.5Z"/></svg>
    </button>
  </div>
</header>
<div class="site-body">
  <nav class="site-nav" id="site-nav" aria-label="Site navigation">
    <div class="nav-group">
      <p class="nav-head">Domains</p>
      <ul>
        {domains.map(d => <li><a href={`/${dslug(d)}/`} class={d===current?'current':undefined}>{d}</a></li>)}
      </ul>
    </div>
    <div class="nav-group">
      <p class="nav-head">Sections</p>
      <ul>
        <li><a href="/press/" class={current==='The Press'?'current':undefined}>The Press</a></li>
        <li><a href="/">About &amp; citation</a></li>
        <li><a href="/">Contribute</a></li>
      </ul>
    </div>
    <p class="nav-license">Free to reproduce. CC BY-SA 4.0. No tracking, no accounts.</p>
  </nav>
  <div class="site-content" id="content">
    <slot />
  </div>
</div>
<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-name">The Common Knowledge Project</p>
    <p>An evergreen, citable reference archive of the concepts that explain how power, money, and work actually function. A project of Parallax Press.</p>
    <p class="footer-license">Text is free to reproduce under CC BY-SA 4.0. No tracking, no accounts.</p>
    <nav class="footer-nav"><a href="/">Browse domains</a><a href="/press/">The Press</a><a href="/">About &amp; citation</a><a href="/">Contribute</a></nav>
  </div>
</footer>
<script is:inline src="/assets/controls.js"></script>
</body>
</html>
