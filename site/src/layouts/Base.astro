---
const { title, page = 'entry', current = '', styles = [] } = Astro.props;
const domains = ['Labor','Capital','The State','Ideology','History','Institutions'];
const dslug = (d) => d.toLowerCase().replace(/&/g,'and').replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'');
---
<!DOCTYPE html>
<html lang="en" data-page={page} data-theme="light" data-parallax="slab" data-relational="density">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<link rel="stylesheet" href="/assets/press.css" />
{styles.map((href) => <link rel="stylesheet" href={href} />)}
<script is:inline>
  (function () { try {
    var r = document.documentElement;
    var t = localStorage.getItem("pp-theme") || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    r.setAttribute("data-theme", t);
    var d = JSON.parse(localStorage.getItem("pp-design") || "{}");
    ["density","domains","search","stats","parallax","relational","domain-layout"].forEach(function (k) {
      if (d[k] != null) r.setAttribute("data-" + k, d[k]); });
  } catch (e) {} })();
</script>
</head>
<body>
<header class="masthead masthead-top">
  <div class="masthead-inner">
    <a class="brand" href="/" aria-label="Parallax Press home">
      <svg class="seal embossed" viewBox="0 0 200 200" aria-hidden="true">
        <defs>
          <path id="seal-top" d="M31.1 63.4 A78 78 0 0 1 168.9 63.4" />
          <path id="seal-bot" d="M31.1 136.6 A78 78 0 0 0 168.9 136.6" />
        </defs>
        <g class="seal-ink" fill="none" stroke-width="1">
          <circle cx="100" cy="100" r="95" /><circle cx="100" cy="100" r="90" stroke-width="3" /><circle cx="100" cy="100" r="64" />
          <line x1="62" y1="116" x2="138" y2="116" stroke-width="1.4" /><line x1="100" y1="60" x2="62" y2="116" stroke-width="1.4" /><line x1="100" y1="60" x2="138" y2="116" stroke-width="1.4" />
          <line x1="100" y1="60" x2="100" y2="116" stroke-width="1" stroke-dasharray="2 3" />
          <path d="M100 124 Q82 119 62 124 L62 145 Q82 141 100 146 Z" stroke-width="1.4" /><path d="M100 124 Q118 119 138 124 L138 145 Q118 141 100 146 Z" stroke-width="1.4" /><line x1="100" y1="124" x2="100" y2="146" stroke-width="1.2" />
        </g>
        <g class="seal-fill" stroke="none">
          <path d="M100 46 L104 54 L112 58 L104 62 L100 70 L96 62 L88 58 L96 54 Z" /><circle cx="62" cy="116" r="2.6" /><circle cx="138" cy="116" r="2.6" /><path d="M22 96 L26 100 L22 104 L18 100 Z" /><path d="M178 96 L182 100 L178 104 L174 100 Z" />
        </g>
        <g stroke="none">
          <text class="seal-type" font-size="13"><textPath href="#seal-top" startOffset="50%" text-anchor="middle">PARALLAX PRESS</textPath></text>
          <text class="seal-type" font-size="12" letter-spacing="0.2em"><textPath href="#seal-bot" startOffset="50%" text-anchor="middle">EST · MMXXVI</textPath></text>
        </g>
      </svg>
      <span class="brand-words"><span class="brand-name">Parallax Press</span><span class="brand-sub">The Common Knowledge Project</span></span>
    </a>
    <nav class="mast-nav" id="mast-nav" aria-label="Domains">
      {domains.map(d => <a href={`/${dslug(d)}/`} class={d===current?'current':undefined}>{d}</a>)}
      <a href="/press/" class={current==='The Press'?'current':undefined}>The Press</a>
    </nav>
    <div class="mast-tools">
      <button class="icon-btn" aria-label="Search the archive" id="mast-search"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="11" cy="11" r="7" /><line x1="16.5" y1="16.5" x2="21" y2="21" stroke-linecap="round" /></svg></button>
      <button class="icon-btn" id="theme-toggle" aria-label="Toggle dark mode"><svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="4.2" /><g stroke-linecap="round"><line x1="12" y1="2.5" x2="12" y2="5" /><line x1="12" y1="19" x2="12" y2="21.5" /><line x1="2.5" y1="12" x2="5" y2="12" /><line x1="19" y1="12" x2="21.5" y2="12" /><line x1="5.2" y1="5.2" x2="6.9" y2="6.9" /><line x1="17.1" y1="17.1" x2="18.8" y2="18.8" /><line x1="18.8" y1="5.2" x2="17.1" y2="6.9" /><line x1="6.9" y1="17.1" x2="5.2" y2="18.8" /></g></svg><svg class="ic-moon" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M20 14.5A8 8 0 0 1 9.5 4 8 8 0 1 0 20 14.5Z" /></svg></button>
    </div>
    <button class="mast-menu" id="mast-menu" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mast-nav"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg></button>
  </div>
</header>
<slot />
<footer class="colophon">
  <div class="colophon-grid">
    <svg class="seal embossed" viewBox="0 0 200 200" aria-hidden="true">
      <g fill="none" stroke="currentColor" stroke-width="1">
        <circle cx="100" cy="100" r="95" /><circle cx="100" cy="100" r="90" stroke-width="3" /><circle cx="100" cy="100" r="64" />
        <line x1="62" y1="116" x2="138" y2="116" stroke-width="1.4" /><line x1="100" y1="60" x2="62" y2="116" stroke-width="1.4" /><line x1="100" y1="60" x2="138" y2="116" stroke-width="1.4" />
        <path d="M100 124 Q82 119 62 124 L62 145 Q82 141 100 146 Z" stroke-width="1.4" /><path d="M100 124 Q118 119 138 124 L138 145 Q118 141 100 146 Z" stroke-width="1.4" /><line x1="100" y1="124" x2="100" y2="146" stroke-width="1.2" />
      </g>
      <g fill="currentColor"><path d="M100 46 L104 54 L112 58 L104 62 L100 70 L96 62 L88 58 L96 54 Z" /><circle cx="62" cy="116" r="2.6" /><circle cx="138" cy="116" r="2.6" /></g>
      <g><text class="seal-type" font-size="13"><textPath href="#seal-top" startOffset="50%" text-anchor="middle">PARALLAX PRESS</textPath></text></g>
    </svg>
    <div class="colo-mid">
      <p class="cm-name">The Common Knowledge Project</p>
      <p>An evergreen, citable reference archive of the concepts that explain how power, money, and work actually function. A project of Parallax Press.</p>
      <p class="license">Free to reproduce · CC BY-SA 4.0 · No tracking · No accounts</p>
    </div>
    <nav class="colo-nav"><a href="/">Browse domains</a><a href="/press/">The Press</a><a href="/">About &amp; citation</a><a href="/">Contribute</a></nav>
  </div>
</footer>
<script is:inline src="/assets/controls.js"></script>
</body>
</html>
