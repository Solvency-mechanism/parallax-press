---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { parseEntry, slug, domainSlug, contentPath } from '../../lib/entry';

export async function getStaticPaths() {
  const corpus = await getCollection('entries');
  // Publish gate: an entry goes live only when its frontmatter has `publish: true`.
  const published = corpus.filter((e) => e.data.title && e.data.domain && e.data.publish === true);
  const entries = published.filter((e) => e.data.format !== 'parallax-post');
  return entries.map((e) => ({
    params: { domain: domainSlug(e.data.domain), slug: slug(e.data.title) },
    props: { entry: e, published, corpus },
  }));
}

const { entry, published, corpus } = Astro.props;
const d = entry.data;

// in-text + related links resolve only to PUBLISHED pages (so no 404s)
const byPub = new Map(published.map((e) => [e.data.title, e]));
const resolve = (t) => (byPub.has(t) ? contentPath(byPub.get(t).data) : null);
// glosses can come from any corpus entry's dek; weights count the WHOLE archive
const byCorpus = new Map(corpus.map((e) => [e.data.title, e]));
function inbound(title) {
  let n = 0;
  for (const e of corpus) {
    const re = /\[\[([^\]|]+)(?:\|[^\]]+)?\]\]/g; let m;
    while ((m = re.exec(e.body || ''))) if (m[1].trim() === title) n++;
  }
  return n;
}

const p = parseEntry(entry.body || '', resolve);
const sections = [
  { kicker: 'What it is',     h: 'What it is',                html: p.whatItIs },
  { kicker: 'Why it matters', h: 'Why it matters',            html: p.whyItMatters },
  { kicker: 'In practice',    h: 'How it works in practice',  html: p.inPractice },
];
const fmtDate = (s) => { if (!s) return ''; const dt = new Date(s); return isNaN(+dt) ? '' : new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).format(dt); };
const today = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date());
const citeUrl = `parallaxpress.org/ckp/${domainSlug(d.domain)}/${slug(d.title)}`;
const related = p.related.map((r) => {
  const t = byCorpus.get(r.title);
  const weight = inbound(r.title);
  return { name: r.alias || r.title, gloss: t?.data.dek || '', href: resolve(r.title) || '#', weight };
});
const title = `${d.title} · The Common Knowledge Project · Parallax Press`;
---
<Base title={title} page="entry" current={d.domain} styles={['/assets/post.css']}>
<main class="wrap article" id="top">
  <article>
    <header class="article-head">
      <h1 class="article-title" set:html={d.title} />
      <p class="article-sub">From The Common Knowledge Project, the free reference archive</p>
    </header>

    {d.dek && <p class="lead">{d.dek}</p>}

    <nav class="toc" aria-label="Contents">
      <p class="toc-head">Contents</p>
      <ol>
        {sections.filter(s => s.html).map((s, i) => (<li><a href={`#sec-${i}`}><span class="toc-n">{i+1}</span>{s.h}</a></li>))}
        {p.parallax.length > 0 && <li><a href="#sec-parallax"><span class="toc-n">{sections.filter(s=>s.html).length+1}</span>What they say vs. what's true</a></li>}
        {p.furtherReading.length > 0 && <li><a href="#sec-reading"><span class="toc-n">{sections.filter(s=>s.html).length + (p.parallax.length>0?2:1)}</span>Further reading</a></li>}
        {related.length > 0 && <li><a href="#sec-seealso"><span class="toc-n">{sections.filter(s=>s.html).length + (p.parallax.length>0?1:0) + (p.furtherReading.length>0?1:0) + 1}</span>See also</a></li>}
      </ol>
    </nav>

    <aside class="infobox">
      <p class="ib-title">{d.domain}{d.entry_number != null && <span class="ib-num"> · Entry № {String(d.entry_number).padStart(2,'0')}</span>}</p>
      <table>
        <tbody>
          <tr><th>Author</th><td>Parallax Press</td></tr>
          {d.published && <tr><th>Published</th><td>{fmtDate(d.published)}</td></tr>}
          {d.revised && <tr><th>Last revised</th><td>{fmtDate(d.revised)}</td></tr>}
        </tbody>
      </table>
      <div class="ib-cite">
        <p class="ib-cite-head">Cite this entry</p>
        <p class="ib-cite-text" id="citation">Parallax Press. “{d.title}.” The Common Knowledge Project{d.published ? `, ${fmtDate(d.published)}` : ''}, {citeUrl}. Accessed {today}.</p>
        <button class="copy-cite" id="copy-cite">Copy citation</button>
      </div>
    </aside>

    {sections.filter(s => s.html).map((s, i) => (
      <section class="article-section" id={`sec-${i}`}>
        <h2>{s.h}</h2>
        <Fragment set:html={s.html} />
      </section>
    ))}

    {p.parallax.length > 0 && (
      <section class="article-section" id="sec-parallax">
        <h2>What they say <span class="muted">vs.</span> what's true</h2>
        <table class="wikitable parallax-table">
          <caption>Common claims and the record against them.</caption>
          <thead><tr><th>What they say</th><th>What's true</th></tr></thead>
          <tbody>
            {p.parallax.map((pr) => (<tr><td><Fragment set:html={pr.say} /></td><td><Fragment set:html={pr.truth} /></td></tr>))}
          </tbody>
        </table>
      </section>
    )}

    {p.furtherReading.length > 0 && (
      <section class="article-section" id="sec-reading">
        <h2>Further reading</h2>
        <ol class="references">
          {p.furtherReading.map((r) => (<li><span class="src-title" set:html={r.title.replace(/^<p>|<\/p>\s*$/g,'')} />{r.meta && <>. <span class="src-meta" set:html={r.meta.replace(/^<p>|<\/p>\s*$/g,'')} /></>}</li>))}
        </ol>
      </section>
    )}

    {related.length > 0 && (
      <section class="article-section" id="sec-seealso">
        <h2>See also</h2>
        <ul class="see-also">
          {related.map((r) => (<li><a href={r.href}>{r.name}</a>{r.gloss && <span class="sa-gloss">, {r.gloss}</span>}{r.weight > 0 && <span class="sa-weight"> (cited by {r.weight})</span>}</li>))}
        </ul>
      </section>
    )}
  </article>
</main>
</Base>
