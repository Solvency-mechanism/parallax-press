---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { postPath } from '../../lib/entry';

const corpus = await getCollection('entries');
const posts = corpus
  .filter((entry) => entry.data.title && entry.data.publish === true && entry.data.format === 'parallax-post')
  .sort((a, b) => String(b.data.published || '').localeCompare(String(a.data.published || '')));
const fmtDate = (value) => {
  if (!value) return '';
  const date = new Date(value);
  return isNaN(+date) ? '' : new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' }).format(date);
};
---
<Base title="The Press — Parallax Press" page="press-index" current="The Press" styles={['/assets/post.css']}>
  <main class="wrap article press-index" id="top">
    <header class="article-head">
      <h1 class="article-title">The Press</h1>
      <p class="article-sub">From The Common Knowledge Project</p>
    </header>
    <p class="lead">Perspectival documents assembled from the Common Knowledge Project for a particular audience, place, or use.</p>
    <ul class="index-list">
      {posts.length === 0 ? <li>No Posts have been published yet.</li> : posts.map((entry) => (
        <li>
          <a href={postPath(entry.data.title)}>{entry.data.title}</a>
          {entry.data.published && <span class="idx-date"> · {fmtDate(entry.data.published)}</span>}
          {entry.data.dek && <div class="idx-gloss">{entry.data.dek}</div>}
        </li>
      ))}
    </ul>
  </main>
</Base>
