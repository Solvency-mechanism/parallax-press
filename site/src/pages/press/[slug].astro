---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { contentPath, postPath, renderPost } from '../../lib/entry';

export async function getStaticPaths() {
  const corpus = await getCollection('entries');
  const published = corpus.filter((e) => e.data.title && e.data.publish === true);
  const posts = published.filter((e) => e.data.format === 'parallax-post');
  return posts.map((e) => ({
    params: { slug: postPath(e.data.title).split('/').filter(Boolean).pop() },
    props: { entry: e, published, corpus },
  }));
}

const { entry, published, corpus } = Astro.props;
const d = entry.data;
const byPub = new Map(published.map((e) => [e.data.title, e]));
const resolve = (title) => byPub.has(title) ? contentPath(byPub.get(title).data) : null;
const post = renderPost(entry.body || '', resolve);
const byCorpus = new Map(corpus.map((e) => [e.data.title, e]));
const related = post.related.map((r) => {
  const target = byCorpus.get(r.title);
  return {
    name: r.alias || r.title,
    href: target?.data?.publish === true ? contentPath(target.data) : null,
    domain: target?.data?.domain || '',
  };
});
const fmtDate = (value) => {
  if (!value) return '';
  const date = new Date(value);
  return isNaN(+date) ? '' : new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' }).format(date);
};
const today = new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date());
const canonicalPath = postPath(d.title);
const citeUrl = `parallaxpress.org${canonicalPath}`;
const title = `${d.title} · Parallax Press`;
---
<Base title={title} page="post" current="The Press" styles={['/assets/post.css']}>
  <main class="wrap article" id="top">
    <article>
      <header class="article-head">
        <span class="post-kicker">Parallax Post</span>
        <h1 class="article-title">{d.title}</h1>
        <p class="article-sub">From The Press, Parallax Press{d.published ? ` · ${fmtDate(d.published)}` : ''}</p>
      </header>
      {d.dek && <p class="lead">{d.dek}</p>}
      <div class="post-body" set:html={post.html} />
      <aside class="infobox post-cite">
        <p class="ib-title">Cite this Post</p>
        <div class="ib-cite">
          <p class="ib-cite-text" id="citation">Parallax Press. “{d.title}.” The Press{d.published ? `, ${fmtDate(d.published)}` : ''}, {citeUrl}. Accessed {today}.</p>
          <button class="copy-cite" id="copy-cite">Copy citation</button>
        </div>
      </aside>
      {related.length > 0 && (
        <section class="article-section" id="sec-seealso"><h2>See also</h2>
          <ul class="see-also">{related.map((item) => (<li><a href={item.href || '#'}>{item.name}</a></li>))}</ul>
        </section>
      )}
    </article>
  </main>
</Base>
